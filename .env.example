#--------------------------------------------------------------------
# Example Environment Configuration File
#
# This file can be used as a starting point for your own
# custom .env files, and it has all of the possible settings
# already set, but commented out.
#
# If you find that you need to change something, take that
# setting out of this file and into your .env file.
#
# The example files all the common settings/options that you might
# want to use, but the defaults will work fine for most people.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

# CI_ENVIRONMENT can be set to development, testing or production
CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

# app.baseURL is the base URL for your application
# IMPORTANT: Set this to http://localhost:8080/project-skripsi/desa_tanjungbaru/public/ for local development
# For production, set to your actual domain
app.baseURL = 'http://localhost:8080/project-skripsi/desa_tanjungbaru/public/'
app.indexPage = ''
app.charset = UTF-8
app.timeZone = Asia/Jakarta

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = db_desa_blanakan
database.default.username = root
database.default.password = 
database.default.DBDriver = MySQLi
database.default.DBPrefix = 
database.default.port = 3306

# Reconnect when there is a loss of connection
database.default.reconnect = true

# The number of times to attempt connection before declaring the service unavailable
database.default.connectionAttempts = 3

# How long to wait between connection attempts, in milliseconds
database.default.connectionDelay = 100

# If true, database errors will be displayed on the rendered page
database.default.failover = []

#--------------------------------------------------------------------
# CACHE
#--------------------------------------------------------------------

cache.default = file
cache.file.storePath = WRITEPATH . 'cache/'
cache.memcached.host = 127.0.0.1
cache.memcached.port = 11211
cache.redis.host = 127.0.0.1
cache.redis.port = 6379
cache.redis.password = ''
cache.redis.database = 0

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

session.driver = FileHandler
session.cookieName = PHPSESSID
session.expiration = 3600
session.matchIP = false
session.timeToUpdate = 300
session.regenerateDestroy = false
session.savePath = WRITEPATH . 'session/'

#--------------------------------------------------------------------
# LOGGING
#--------------------------------------------------------------------

log.threshold = 4
log.dateFormat = Y-m-d H:i:s
log.handlers.CodeIgniter\Logs\Handlers\FileHandler:
  handles = '400:8'

#--------------------------------------------------------------------
# EMAIL
#--------------------------------------------------------------------

email.fromEmail = noreply@desa-blanakan.local
email.fromName = 'Desa Blanakan'
email.protocol = mail
email.SMTPHost = localhost
email.SMTPUser = ''
email.SMTPPass = ''
email.SMTPPort = 25
email.SMTPCrypto = tls
email.mailType = html
email.charset = UTF-8
email.newline = '\r\n'
email.validation = true

#--------------------------------------------------------------------
# SECURITY
#--------------------------------------------------------------------

security.tokenName = csrf_token_name
security.headerName = X-CSRF-TOKEN
security.cookieName = csrf_cookie_name
security.expires = 7200
security.regenerate = true
security.redirect = true
security.samesite = 'Lax'

#--------------------------------------------------------------------
# CONTENT SECURITY POLICY
#--------------------------------------------------------------------

CSPEnabled = false

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

encryption.key = 
encryption.driver = OpenSSL

#--------------------------------------------------------------------
# HONEYPOT
#--------------------------------------------------------------------

honeypot.hidden = 'true'
honeypot.label = 'Fill This If You Are Human:'
honeypot.name = 'bot'
honeypot.template = '<label>{label}</label><input type="text" name="{name}" value=""/>'
honeypot.container = '<div style="display:none">{template}</div>'

#--------------------------------------------------------------------
# FORMAT
#--------------------------------------------------------------------

format.imageHandler = gd
format.jsonFormat = JSON_UNESCAPED_SLASHES

#--------------------------------------------------------------------
# CURL
#--------------------------------------------------------------------

curl.timeout = 0

#--------------------------------------------------------------------
# ADMIN / DEVELOPMENT SETTINGS
#--------------------------------------------------------------------

# IMPORTANT: Ubah nilai-nilai di bawah ini di production server
ADMIN_EMAIL = admin@desa-blanakan.local
ADMIN_NAME = Administrator
DATABASE_BACKUP_DIR = WRITEPATH . 'backups/'
UPLOAD_MAX_FILE_SIZE = 5120

# Set ke false di production!
SHOW_DEBUG_TOOLBAR = true
