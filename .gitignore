# CodeIgniter 4 Specific
#-------------------------
/writable/cache/*
!/writable/cache/index.html
/writable/debugbar/*
!/writable/debugbar/index.html
/writable/logs/*
!/writable/logs/index.html
/writable/session/*
!/writable/session/index.html
/writable/uploads/*
!/writable/uploads/index.html

# Environment Files
#-------------------------
.env
.env.production
.env.development
*.env

# User Generated Content
#-------------------------
/public/uploads/*
!/public/uploads/index.html
/public/berita/*
!/public/berita/index.html
/public/galeri/*
!/public/galeri/index.html

# Backup Files
#-------------------------
/writable/backups/*
*.sql
*.sql.gz
*.sql.zip
*.backup

# Composer
#-------------------------
/vendor/
composer.lock

# Operating System Files
#-------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE Files
#-------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# Node Modules (if using npm)
#-------------------------
node_modules/
npm-debug.log
yarn-error.log

# Build Files
#-------------------------
/build/
/dist/
*.min.js
*.min.css

# Test Files
#-------------------------
/tests/coverage/
phpunit.xml
.phpunit.result.cache

# Temporary Files
#-------------------------
*.tmp
*.temp
*.log
*.pid
*.seed
*.pid.lock

# Security
#-------------------------
/app/Config/Encryption.php.backup
/app/Config/Database.php.backup
*.key
*.pem
*.crt

# Documentation (optional - remove if you want to track)
#-------------------------
# *.md

# Specific Test Files
#-------------------------
/public/check_*.php
/public/test_*.php
/public/process_*_test.php
/public/delete_duplicate_*.php
